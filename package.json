{
  "name": "flexipayroll",
  "description": "A lightweight, browser-based payroll management system for SMEs",
  "private": true,
  "version": "7.3.0",
  "type": "module",
  "license": "AGPL-3.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:offline": "BASE=./ vite build",
    "preview": "vite preview",
    "test": "node test/payroll.test.js && node test/print.test.js",
    "serve": "npm run build:offline && npx serve dist -l 3000",
    "serve:pages": "npm run build && rm -rf .tmp-serve && mkdir -p .tmp-serve/flexipayroll && cp -r dist/* .tmp-serve/flexipayroll/ && npx serve .tmp-serve -l 3000"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "sass": "^1.89.2",
    "svelte": "^5.53.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.3.0"
  },
  "dependencies": {
    "@fontsource/baloo-2": "^5.2.6",
    "@fontsource/bungee": "^5.2.6",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@iconify-json/tabler": "^1.2.23",
    "@iconify/svelte": "^5.0.0",
    "bit-grid-component": "^0.3.0",
    "platform-compat-screen": "^0.0.1"
  }
}
